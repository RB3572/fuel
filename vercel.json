{
  "env": {
    "GEMINI_MEAL_PLAN_MODEL": "gemini-3.1-flash-lite"
  },
  "rewrites": [
    {
      "source": "/api/health/import-text",
      "destination": "/api/health/import"
    },
    {
      "source": "/api/context",
      "destination": "/api/mlog?fuel_route=user-context"
    },
    {
      "source": "/api/meal-plan",
      "destination": "/api/mlog?fuel_route=meal-plan"
    },
    {
      "source": "/.well-known/oauth-protected-resource",
      "destination": "/api/mlog?fuel_route=protected-resource"
    },
    {
      "source": "/.well-known/oauth-authorization-server",
      "destination": "/api/mlog?fuel_route=authorization-server"
    },
    {
      "source": "/oauth/register",
      "destination": "/api/mlog?fuel_route=register"
    },
    {
      "source": "/oauth/client-metadata",
      "destination": "/api/mlog?fuel_route=client-metadata"
    },
    {
      "source": "/oauth/authorize",
      "destination": "/api/mlog?fuel_route=authorize"
    },
    {
      "source": "/oauth/token",
      "destination": "/api/mlog?fuel_route=token"
    },
    {
      "source": "/mcp",
      "destination": "/api/mcp"
    },
    {
      "source": "/mcp-info",
      "destination": "/api/mlog?fuel_route=info"
    }
  ]
}
